# William Tucker Solutions marketing site — example environment file.
# Copy to `.env` (gitignored) and fill in real values for local dev.
# In production these are set in the Railway dashboard.

# Anthropic API (chatbot — existing)
ANTHROPIC_API_KEY=sk-ant-...

# WTSAdmin Supabase (contact form writes leads into the admin's contacts table)
# Use the SERVICE_ROLE key, NOT the publishable anon key — the endpoint runs
# server-side and bypasses RLS to insert into the contacts table directly.
WTSADMIN_SUPABASE_URL=https://<project-ref>.supabase.co
WTSADMIN_SUPABASE_SERVICE_KEY=eyJ...

# Resend (notification + auto-reply emails from the contact form)
# The From address must be on a verified domain (williamtucker.ca).
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@williamtucker.ca
WTSADMIN_NOTIFY_EMAIL=william@williamtucker.ca

# Cloudflare Turnstile (invisible spam check on the contact form)
# Register at cloudflare.com/products/turnstile (free), create a widget for
# williamtucker.ca, and set BOTH keys here. The site key is public — it
# ships to browsers via /api/contact-config — but lives here rather than
# in the repo so it rotates without code edits. The secret key is server-
# side only. The Cloudflare test keys (site: 1x00000000000000000000AA /
# secret: 1x0000000000000000000000000000000AA) always pass and are useful
# for local dev only.
TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Port (defaults to 3000)
PORT=3000
