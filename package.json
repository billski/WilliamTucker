    "start": "node server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/cli": "^4.2.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "resend": "^6.12.3",
    "tailwindcss": "^4.2.2"
  }
}
